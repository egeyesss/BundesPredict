# Copy to .env and fill in. Never commit the real .env.

# Postgres (matches infra/docker-compose.yml defaults)
POSTGRES_USER=bundespredict
POSTGRES_PASSWORD=bundespredict
POSTGRES_DB=bundespredict
DATABASE_URL=postgresql://bundespredict:bundespredict@db:5432/bundespredict

# Anthropic API (for the chat/agent part — not needed yet)
ANTHROPIC_API_KEY=

# Frontend → API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
