# Next.js dev server. Build context is the repo root.
FROM node:20-slim

WORKDIR /app

COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci

COPY apps/web ./

EXPOSE 3000
# Dev server for local work. Swap for `next build` + `next start` when deploying.
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0"]
